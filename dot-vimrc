set encoding=utf-8
set fileformat=unix
set fileformats=unix,dos

filetype plugin indent on
syntax on

set expandtab
set shiftwidth=4
set softtabstop=4
set tabstop=4
set smartindent
set number
set showmatch
set backspace=indent,eol,start
set completeopt=menuone,noinsert,noselect

let mapleader = " "
nnoremap <Leader>cd :Ex<CR>

